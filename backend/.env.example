# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=securedata

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Stellar Soroban
SOROBAN_NETWORK_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
IDENTITY_REGISTRY_CONTRACT_ID=
VERIFICATION_CONTRACT_ID=
ACCESS_CONTROL_CONTRACT_ID=
DATA_SHARING_CONTRACT_ID=

# IPFS / Pinata
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/

# Groq AI
GROQ_API_KEY=

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key

# Rate limiting (ttl in ms, limit = max requests per ttl window)
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# Credential audit logging
# Secret used to HMAC-chain audit entries (falls back to JWT_SECRET if unset)
AUDIT_HMAC_SECRET=your-audit-hmac-secret-change-in-production
# Comma-separated wallet addresses allowed to access the audit query interface
ADMIN_WALLETS=
# Retention window in days; entries older than this are purged by the worker
AUDIT_RETENTION_DAYS=365
# How often the retention worker sweeps, in hours
AUDIT_RETENTION_SWEEP_HOURS=24
# Set to "false" to disable the background retention worker
AUDIT_RETENTION_ENABLED=true
